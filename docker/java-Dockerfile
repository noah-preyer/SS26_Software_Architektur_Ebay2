FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive
ENV SPRING_BOOT_CLI_VERSION=4.0.6
ENV SPRING_BOOT_CLI_HOME=/opt/spring-boot-cli
ENV PATH="${SPRING_BOOT_CLI_HOME}/bin:${PATH}"

RUN apt-get update && apt-get install -y \
    ca-certificates \
    curl \
    git \
    unzip \
    zip \
    sudo \
    bash-completion \
    openjdk-21-jdk \
    maven \
    postgresql-client \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

RUN mkdir -p ${SPRING_BOOT_CLI_HOME} \
    && curl -fsSL \
       "https://repo.maven.apache.org/maven2/org/springframework/boot/spring-boot-cli/${SPRING_BOOT_CLI_VERSION}/spring-boot-cli-${SPRING_BOOT_CLI_VERSION}-bin.tar.gz" \
       -o /tmp/spring-boot-cli.tar.gz \
    && tar -xzf /tmp/spring-boot-cli.tar.gz -C ${SPRING_BOOT_CLI_HOME} --strip-components=1 \
    && rm /tmp/spring-boot-cli.tar.gz \
    && ln -s ${SPRING_BOOT_CLI_HOME}/bin/spring /usr/local/bin/spring

RUN echo "ubuntu ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/ubuntu \
    && chmod 0440 /etc/sudoers.d/ubuntu

USER ubuntu

WORKDIR /workspace