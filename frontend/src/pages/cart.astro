---
import Layout from "../layouts/Layout.astro";
import Cart from "../components/cart/Cart.jsx";
---

<Layout title="Warenkorb">
  <div class="pt-10 pb-8 border-b-2 border-[#111111] mb-10">
    <p class="text-[#E8400C] font-black text-xs uppercase tracking-[0.2em] mb-3">Einkaufen</p>
    <h1 class="page-title mb-4">Warenkorb</h1>
    <p class="text-[#666666] text-lg">Prüfe deine Auswahl und schließe deinen Kauf ab.</p>
  </div>
  <Cart client:load />
</Layout>
